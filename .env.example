# Aegis Follow-Up local/demo defaults.
# Do not place real secrets, FHIR tokens, API keys, PHI, or customer identifiers here.

# Profile: local, demo, staging, pilot. Production is future roadmap work.
APP_ENV=local
LOG_LEVEL=INFO

# Synthetic fixture mode is the safe default for local and public demo use.
FIXTURE_MODE=true
FHIR_SYNTHETIC_BUNDLE_PATH=data/synthetic_patient_bundle.json

# Keep false unless deliberately running the optional read-only FHIR connectivity proof.
LIVE_FHIR_READS_ENABLED=false

HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=

# Prompt Opinion-compatible MCP transport.
MCP_TRANSPORT=streamable-http
MCP_JSON_RESPONSE=false
MCP_STATELESS_HTTP=false

# LLM fallback is the safe default. Configure Gemini only in managed secrets.
LLM_PROVIDER=disabled
GEMINI_API_KEY=
LLM_MODEL=gemini-2.5-flash
LLM_TIMEOUT_SECONDS=20
LLM_MAX_OUTPUT_TOKENS=700
